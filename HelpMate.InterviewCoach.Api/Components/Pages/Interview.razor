@page "/interview/{SessionId:int}"
@inject ApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Interview - HelpMate Interview Coach</PageTitle>

@if (!Auth.IsSignedIn)
{
    <div class="card">
        <h1>Sign in first</h1>
        <a class="btn" href="/login">Sign in</a>
    </div>
}
else if (_session is null)
{
    <div class="card"><span class="spinner"></span> <span class="muted">Loading the interview...</span></div>
}
else
{
    <div class="row" style="margin-bottom:1.25rem">
        <div>
            <h1>@_session.TargetRole</h1>
            <p class="muted small" style="margin:0">
                Question @_session.Questions.Count of @MaxQuestions
                @if (_session.AverageScore is not null)
                {
                    <span>&middot; average so far <span class="score">@_session.AverageScore.Value.ToString("0.0")</span></span>
                }
            </p>
        </div>
        <a class="btn btn-ghost" href="/dashboard">Back</a>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-error">@_error</div>
    }

    @if (_session.Status == InterviewSessionStatus.Completed)
    {
        <div class="card">
            <h2>Interview finished</h2>
            <p class="muted">
                You scored <span class="score">@(_session.AverageScore?.ToString("0.0") ?? "-") / 10</span> on average
                across @_session.Questions.Count questions.
            </p>
            <div class="actions">
                <a class="btn" href="/dashboard">Back to dashboard</a>
                <a class="btn btn-ghost" href="/sessions/@_session.Id">Review the full transcript</a>
            </div>
        </div>
    }

    @foreach (var question in _session.Questions.OrderBy(q => q.Order))
    {
        var isCurrent = question.Answer is null;

        <div class="card qa @(question.Answer?.Score is not null ? "evaluated" : "")">
            <div class="qa-head">
                <span class="qa-number">Question @question.Order</span>
                @if (question.Answer?.Score is not null)
                {
                    <span class="score">@question.Answer.Score / 10</span>
                }
            </div>

            <div class="qa-question">@question.Text</div>

            @if (question.Answer is not null)
            {
                <div class="qa-answer">@question.Answer.Text</div>

                @if (question.Answer.FeedbackText is not null)
                {
                    <div class="qa-feedback">
                        <span class="qa-feedback-label">Coach feedback</span>
                        @question.Answer.FeedbackText
                    </div>
                }
                else
                {
                    <p class="dim small" style="margin:0">Waiting for the coach to review this answer.</p>
                }
            }
            else if (isCurrent)
            {
                <div class="field">
                    <label for="answer">Your answer</label>
                    <textarea id="answer" @bind="_answer" @bind:event="oninput"
                              placeholder="Answer in your own words. There is no keyword matching - explain your reasoning."></textarea>
                </div>

                <button class="btn" @onclick="() => SubmitAsync(question.Id)"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_answer))">
                    @if (_busy)
                    {
                        <span class="spinner"></span>
                        <span>@_busyLabel</span>
                    }
                    else
                    {
                        <span>Submit answer</span>
                    }
                </button>
            }
        </div>
    }

    @if (_session.Status != InterviewSessionStatus.Completed && !_session.Questions.Any(q => q.Answer is null))
    {
        <div class="card">
            <p class="muted" style="margin:0 0 1rem">
                @if (_session.Questions.Count == 0)
                {
                    <span>Ready when you are.</span>
                }
                else
                {
                    <span>Answer reviewed. Continue when you are ready.</span>
                }
            </p>

            <button class="btn btn-lg" @onclick="AdvanceAsync" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>@_busyLabel</span>
                }
                else
                {
                    <span>@(_session.Questions.Count == 0 ? "Ask the first question" : "Continue")</span>
                }
            </button>
        </div>
    }
}

@code {
    private const int MaxQuestions = 5;

    [Parameter]
    public int SessionId { get; set; }

    private SessionDetailResponse? _session;
    private string _answer = string.Empty;
    private string? _error;
    private bool _busy;
    private string _busyLabel = "Working...";

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsSignedIn)
        {
            _session = await Api.GetSessionAsync(SessionId);
        }
    }

    private async Task AdvanceAsync()
    {
        _busy = true;
        _busyLabel = "The coach is thinking...";
        _error = null;

        var (session, error) = await Api.AdvanceAsync(SessionId);

        if (session is not null)
        {
            _session = session;
        }
        else
        {
            _error = error;
        }

        _busy = false;
    }

    private async Task SubmitAsync(int questionId)
    {
        _busy = true;
        _busyLabel = "Sending your answer...";
        _error = null;

        var (session, error) = await Api.SubmitAnswerAsync(SessionId, questionId, _answer.Trim());

        if (session is null)
        {
            _error = error;
            _busy = false;
            return;
        }

        _session = session;
        _answer = string.Empty;

        // Reviewing the answer and asking the next question is one continuous step for the user.
        _busyLabel = "The coach is reviewing your answer...";
        StateHasChanged();

        var (advanced, advanceError) = await Api.AdvanceAsync(SessionId);

        if (advanced is not null)
        {
            _session = advanced;
        }
        else
        {
            _error = advanceError;
        }

        _busy = false;
    }
}
