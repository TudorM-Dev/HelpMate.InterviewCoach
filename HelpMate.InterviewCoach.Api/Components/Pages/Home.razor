@page "/"
@inject AuthState Auth

<PageTitle>HelpMate Interview Coach</PageTitle>

<section class="landing">
    <span class="badge badge-live">AI interview practice</span>

    <h1>Practise the interview<br />before it counts.</h1>

    <p class="lede">
        An AI agent asks you real technical questions, reads your answers and scores them out of ten.
    </p>

    <div class="landing-actions">
        @if (Auth.IsSignedIn)
        {
            <a class="btn btn-lg" href="/dashboard">Go to dashboard</a>
        }
        else
        {
            <a class="btn btn-lg" href="/login?demo=1">See a sample interview</a>
            <a class="btn btn-ghost btn-lg" href="/register">Create account</a>
        }
    </div>

    @if (!Auth.IsSignedIn)
    {
        <p class="dim small landing-note">No sign-up needed for the sample.</p>
    }
</section>
