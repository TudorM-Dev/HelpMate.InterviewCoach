@page "/"
@inject AuthState Auth

<PageTitle>HelpMate Interview Coach</PageTitle>

<section class="landing">
    <span class="badge badge-live">AI interview practice</span>

    <h1>Practise the interview<br />before it counts.</h1>

    <p class="lede">
        An AI coach asks you real technical questions, reads your answers, scores them out of ten
        and tells you exactly what was missing.
    </p>

    <div class="landing-actions">
        @if (Auth.IsSignedIn)
        {
            <a class="btn btn-lg" href="/dashboard">Go to dashboard</a>
        }
        else
        {
            <a class="btn btn-lg" href="/login?demo=1">See a sample interview</a>
            <a class="btn btn-ghost btn-lg" href="/register">Create account</a>
        }
    </div>

    @if (!Auth.IsSignedIn)
    {
        <p class="dim small landing-note">No sign-up needed for the sample.</p>
    }
</section>

<div class="steps">
    <div class="step">
        <div class="step-num">01</div>
        <h3>Pick a role and a level</h3>
        <p>From internship to senior. The coach calibrates both its questions and its marking to the level you choose.</p>
    </div>
    <div class="step">
        <div class="step-num">02</div>
        <h3>Answer in your own words</h3>
        <p>Five questions, one at a time. No multiple choice, no keyword matching — you explain, it reads.</p>
    </div>
    <div class="step">
        <div class="step-num">03</div>
        <h3>Get scored feedback</h3>
        <p>Every answer gets a mark out of ten and a concrete note on what was right and what you left out.</p>
    </div>
</div>
