@page "/dashboard"
@inject ApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Dashboard - HelpMate Interview Coach</PageTitle>

@if (!Auth.IsSignedIn)
{
    <div class="card">
        <h1>Sign in first</h1>
        <p class="muted">You need an account to run an interview.</p>
        <a class="btn" href="/login">Sign in</a>
    </div>
}
else
{
    <div class="page-head">
        <div>
            <p class="eyebrow">Your practice</p>
            <h1>Interviews</h1>
        </div>
        <p class="muted small meta">
            @if (_sessions.Count == 0)
            {
                <span>Nothing here yet — start your first one below.</span>
            }
            else
            {
                <span><span class="mono">@_sessions.Count</span> session@(_sessions.Count == 1 ? "" : "s") so far</span>
            }
        </p>
    </div>

    <div class="card">
        <h3>Start a new interview</h3>
        <p class="muted small">Name the role you are preparing for and pick your level. The coach adapts its questions and its marking to both.</p>

        @if (_error is not null)
        {
            <div class="alert alert-error">@_error</div>
        }

        <div class="actions" style="align-items:flex-end">
            <div style="flex:1; min-width:15rem">
                <label for="role">Target role</label>
                <input id="role" @bind="_targetRole" @bind:event="oninput" placeholder=".NET Backend" />
            </div>
            <div style="min-width:10rem">
                <label for="difficulty">Level</label>
                <select id="difficulty" @bind="_difficulty">
                    <option value="@InterviewDifficulty.Internship">Internship</option>
                    <option value="@InterviewDifficulty.Junior">Junior</option>
                    <option value="@InterviewDifficulty.Mid">Mid</option>
                    <option value="@InterviewDifficulty.Senior">Senior</option>
                </select>
            </div>
            <button class="btn" @onclick="StartAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_targetRole))">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>Starting...</span>
                }
                else
                {
                    <span>Start interview</span>
                }
            </button>
        </div>

        <div class="actions" style="margin-top:0.9rem">
            @foreach (var suggestion in Suggestions)
            {
                <button class="btn btn-chip" @onclick="() => _targetRole = suggestion">@suggestion</button>
            }
        </div>
    </div>

    @if (_scored.Count > 1)
    {
        <div class="card">
            <h3>Scores over time</h3>
            <div class="trend">
                @foreach (var session in _scored)
                {
                    <div class="trend-row">
                        <span class="muted">@session.TargetRole</span>
                        <div class="trend-bar">
                            <div class="trend-fill" style="width:@((session.AverageScore ?? 0) * 10)%"></div>
                        </div>
                        <span class="@ScoreDisplay.CssClass(session.AverageScore)">@session.AverageScore?.ToString("0.0")</span>
                    </div>
                }
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="card"><span class="spinner"></span> <span class="muted">Loading your history...</span></div>
    }
    else
    {
        @foreach (var session in _sessions)
        {
            <a class="card card-tight card-link" href="/sessions/@session.Id">
                <div class="row">
                    <div>
                        <strong>@session.TargetRole</strong>
                        <div class="dim small">
                            <span class="mono">@session.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</span>
                            &middot; @session.QuestionCount question@(session.QuestionCount == 1 ? "" : "s")
                        </div>
                    </div>
                    <div class="actions" style="align-items:center; flex-wrap:nowrap">
                        @if (session.AverageScore is not null)
                        {
                            <span class="@ScoreDisplay.CssClass(session.AverageScore)">@session.AverageScore.Value.ToString("0.0") / 10</span>
                        }
                        <span class="badge @(session.Status == InterviewSessionStatus.Completed ? "" : "badge-live")">
                            @(session.Status == InterviewSessionStatus.Completed ? "Completed" : "In progress")
                        </span>
                    </div>
                </div>
            </a>
        }
    }
}

@code {
    private static readonly string[] Suggestions =
    [
        ".NET Backend", "C# Fundamentals", "SQL & Databases", "Frontend React"
    ];

    private IReadOnlyList<SessionSummaryResponse> _sessions = [];
    private List<SessionSummaryResponse> _scored = [];
    private string _targetRole = string.Empty;
    private InterviewDifficulty _difficulty = InterviewDifficulty.Internship;
    private string? _error;
    private bool _busy;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsSignedIn)
        {
            await LoadAsync();
        }

        _loading = false;
    }

    private async Task LoadAsync()
    {
        _sessions = await Api.GetSessionsAsync();

        _scored = _sessions
            .Where(s => s.AverageScore is not null)
            .OrderBy(s => s.CreatedAt)
            .ToList();
    }

    private async Task StartAsync()
    {
        _busy = true;
        _error = null;

        var (session, error) = await Api.CreateSessionAsync(_targetRole.Trim(), _difficulty);

        _busy = false;

        if (session is not null)
        {
            Nav.NavigateTo($"/interview/{session.Id}");
        }
        else
        {
            _error = error;
        }
    }
}
